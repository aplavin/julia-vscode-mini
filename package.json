{
  "name": "julia-mini",
  "displayName": "Julia Mini",
  "description": "Lean Julia support for VS Code without background Julia processes.",
  "version": "0.1.0",
  "publisher": "aplavin",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/aplavin/julia-vscode-mini#readme",
  "bugs": {
    "url": "https://github.com/aplavin/julia-vscode-mini/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aplavin/julia-vscode-mini.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "julia",
    "repl",
    "profiler",
    "unicode",
    "go to definition"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:julia",
    "onCommand:julia.openRepl",
    "onCommand:julia.startRepl",
    "onCommand:language-julia.executeCodeBlockOrSelection",
    "onCommand:language-julia.executeCodeBlockOrSelectionAndMove",
    "onCommand:language-julia.executeCell",
    "onCommand:language-julia.executeCellAndMove",
    "onCommand:language-julia.executeFile",
    "onCommand:julia.openProfiler",
    "onCommand:julia.clearProfileHeat"
  ],
  "contributes": {
    "languages": [
      {
        "id": "julia",
        "aliases": [
          "Julia",
          "julia"
        ],
        "extensions": [
          ".jl"
        ]
      },
      {
        "id": "juliamarkdown",
        "aliases": [
          "Julia Markdown",
          "juliamarkdown"
        ],
        "extensions": [
          ".jmd"
        ]
      }
    ],
    "grammars": [
      {
        "language": "julia",
        "scopeName": "source.julia",
        "path": "./syntaxes/julia_vscode.json"
      },
      {
        "language": "juliamarkdown",
        "scopeName": "text.html.markdown.julia",
        "path": "./syntaxes/juliamarkdown.json"
      },
      {
        "scopeName": "markdown.julia.codeblock",
        "path": "./syntaxes/juliacodeblock.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.julia": "julia"
        }
      }
    ],
    "commands": [
      {
        "command": "julia.openRepl",
        "title": "Julia: Open REPL"
      },
      {
        "command": "julia.startRepl",
        "title": "Julia: Start REPL"
      },
      {
        "command": "language-julia.executeCodeBlockOrSelection",
        "title": "Julia: Execute Code in REPL"
      },
      {
        "command": "language-julia.executeCodeBlockOrSelectionAndMove",
        "title": "Julia: Execute Code in REPL and Move"
      },
      {
        "command": "language-julia.executeCell",
        "title": "Julia: Execute Code Cell in REPL"
      },
      {
        "command": "language-julia.executeCellAndMove",
        "title": "Julia: Execute Code Cell in REPL and Move"
      },
      {
        "command": "language-julia.executeFile",
        "title": "Julia: Execute File in REPL"
      },
      {
        "command": "julia.openProfiler",
        "title": "Julia: Open Profiler"
      },
      {
        "command": "julia.clearProfileHeat",
        "title": "Julia: Clear Profile Heat"
      },
      {
        "command": "julia.symbolIndex.rebuild",
        "title": "Julia: Rebuild Symbol Index"
      },
      {
        "command": "julia.installCli",
        "title": "Julia: Install julia-vscode CLI"
      }
    ],
    "configuration": {
      "title": "Julia",
      "properties": {
        "julia.executablePath": {
          "type": "string",
          "default": "julia",
          "description": "Julia executable path or command name."
        },
        "julia.executableArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments inserted immediately after the Julia executable, such as juliaup channel selectors."
        },
        "julia.additionalArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional Julia arguments inserted before the profiler bootstrap script."
        },
        "julia.NumThreads": {
          "type": [
            "string",
            "number",
            "null"
          ],
          "default": "auto",
          "description": "Value passed to --threads. Use null or an empty string to omit --threads."
        },
        "julia.cellDelimiters": {
          "type": "array",
          "default": [
            "^[ \\t]?#[ \\t]#+",
            "^##(?!#)",
            "^#([ \\t]?)%%",
            "^##([ \\t]?)-",
            "^##([ \\t]?)\\+"
          ],
          "items": {
            "type": "string"
          },
          "description": "Cell delimiter regular expressions for Julia files."
        },
        "julia.symbolIndex.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the parser-based symbol index (Outline, workspace symbols, Go to Definition)."
        },
        "julia.symbolIndex.juliaSourceRoots": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Explicit Base/stdlib source roots to index. Used as a fallback/escape hatch when the Julia metadata probe cannot locate them."
        },
        "julia.symbolIndex.maxDefinitionResults": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of ranked locations returned for Go to Definition."
        }
      }
    },
    "keybindings": [
      {
        "command": "language-julia.executeCodeBlockOrSelection",
        "key": "ctrl+enter",
        "when": "editorTextFocus && activeEditor != workbench.editor.notebook && editorLangId == julia"
      },
      {
        "command": "language-julia.executeCodeBlockOrSelectionAndMove",
        "key": "shift+enter",
        "when": "editorTextFocus && activeEditor != workbench.editor.notebook && editorLangId == julia"
      },
      {
        "command": "language-julia.executeCell",
        "key": "alt+enter",
        "when": "editorTextFocus && activeEditor != workbench.editor.notebook && editorLangId == julia"
      },
      {
        "command": "language-julia.executeCellAndMove",
        "key": "alt+shift+enter",
        "when": "editorTextFocus && activeEditor != workbench.editor.notebook && editorLangId == julia"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "generate-unicode-completions": "julia --startup-file=no scripts/generate_unicode_completions.jl",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "npm run compile && node --test test/*.test.js",
    "package": "vsce package --out julia-mini.vsix",
    "install-extension-locally": "npm run package && (code --install-extension julia-mini.vsix --force || \"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --install-extension julia-mini.vsix --force)"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.4.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@plutojl/lezer-julia": "^1.1.0",
    "smol-toml": "^1.7.0"
  }
}
